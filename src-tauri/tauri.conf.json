{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TermDeck",
  "version": "0.2.0",
  "identifier": "com.jonathanpeters.termdeck",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TermDeck",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "dragDropEnabled": true,
        "backgroundColor": "#0f0f11"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:1420 ws://127.0.0.1:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "deb"],
    "category": "DeveloperTool",
    "shortDescription": "A workspace-first terminal deck",
    "longDescription": "A Rust-powered terminal workspace with automatic tiling, drag-and-drop organization, and keyboard navigation.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
